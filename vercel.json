{
  "buildCommand": "cd pmcs-app && npm install && npm run build",
  "outputDirectory": "pmcs-app/build",
  "framework": null,
  "rewrites": [
    { "source": "/app",     "destination": "/index.html" },
    { "source": "/app/(.*)", "destination": "/index.html" },
    { "source": "/",        "destination": "/landing.html" }
  ]
}
